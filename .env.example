# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=production

# MySQL Database
MYSQL_HOST=your-database-host.com
MYSQL_USER=database_user
MYSQL_PASSWORD=database_password
MYSQL_DB=cgs

# Optional: Google Maps API for Geofencing/Geocoding
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Email Configuration (if you add email features later)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
